<p style="color: green"><%= notice %></p>

<%= render @ticket %>

<div>
  <% if params[:from] == "tickets" %>
    <%= link_to "Back to Tickets", tickets_path, class: "btn btn-secondary" %>
  <% else %>
    <%= link_to "Back to Shows", movie_show_path(@ticket.show.movie, @ticket.show, from: "show"), class: "btn btn-secondary" %>
  <% end %>

  <% if current_user.is_admin? %>
    <%= link_to "Delete Ticket", delete_ticket_path(@ticket), data: { confirm: "Are you sure you want to delete this ticket?" } %>
  <% end %>

  <% if @ticket.status != "Cancelled" %>
    <%= form_with model: @ticket, url: movie_show_ticket_path(@ticket.show.movie, @ticket.show, @ticket, from: params[:from]), method: :patch do |form| %>
      <%= form.hidden_field :status, value: "Cancelled" %>
      <%= form.hidden_field :from, value: params[:from] %> <!-- ✅ Preserve the 'from' param -->
      <%= form.submit "Cancel Ticket", class: "btn btn-warning", data: { confirm: "Are you sure you want to cancel this ticket?" } %>
    <% end %>
  <% else %>
    <p style="color: red;"><strong>This ticket has been cancelled.</strong></p>
  <% end %>
</div>
