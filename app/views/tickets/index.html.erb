<p style="color: green"><%= notice %></p>

<% content_for :title, "Tickets" %>

<h1>Tickets</h1>

<div id="tickets">
  <% @tickets.each do |ticket| %>
    <%= render ticket %>
    <p>
      <%= link_to "Show this ticket", movie_show_ticket_path(ticket.show.movie, ticket.show, ticket) %>
    </p>
  <% end %>
</div>

