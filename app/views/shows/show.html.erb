<p style="color: green"><%= notice %></p>

<%= render @show %>

<div>
  <% if current_user&.is_admin %>
    <%= link_to "Edit this show", edit_movie_show_path(@show) %> |
    <%= button_to "Destroy this show", movie_show_path(@show.movie, @show), method: :delete %> |
  <%end%>
  <%= link_to "Back to shows", movie_shows_path(@show.movie) %>
</div>
