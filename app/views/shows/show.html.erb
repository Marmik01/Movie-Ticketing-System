<p style="color: green"><%= notice %></p>

<%= render @show %>

<div class="actions">
  <% if current_user&.is_admin %>
    <div class="admin-actions">
      <%= link_to "Edit this Show", edit_movie_show_path(@show), class: "btn btn-warning" %>
      <%= link_to "Delete Show", delete_movie_show_path(@show.movie, @show),
                  class: "btn btn-danger",
                  data: { confirm: "Are you sure you want to delete this show?" } %>

    </div>
  <% end %>

  <br> <!-- Separator for better spacing -->

  <% if @show.available_seats > 0 %>
    <%= form_with url: movie_show_tickets_path(@show.movie, @show), method: :post, id: "purchaseTicketForm" do |form| %>
      <%= form.hidden_field :user_id, value: current_user.id %>
      <%= form.hidden_field :show_id, value: @show.id %>
      <%= form.submit "Purchase Ticket", class: "btn btn-success", data: { confirm: "Confirm the purchase for ticket at Price $#{@show.ticket_price}?" }, from: "show" %>
    <% end %>
  <% else %>
    <p style="color: red;"><strong>Sold Out</strong></p>
  <% end %>

  <br> <!-- Another separator for better spacing -->

  <div class="navigation">
    <%= link_to "Back to Shows", movie_shows_path(@show.movie), class: "btn btn-secondary" %>
  </div>
</div>
