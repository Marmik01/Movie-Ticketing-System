<p style="color: green"><%= notice %></p>

<% content_for :title, "Shows" %>

<h1>Available Shows for <%= @movie.title %></h1>

<div id="shows">
  <% @shows.each do |show| %>
    <%= render show %>

    <p>
      <%= link_to "Book this show", movie_show_path(@movie, show), class: "btn btn-success" %>
    </p>

    <% if current_user&.is_admin %>
      <div class="admin-actions">
        <%= link_to "Edit", edit_movie_show_path(@movie, show), class: "btn btn-warning btn-sm" %>
        <%= link_to "Delete Show", delete_movie_show_path(@movie, show), class: "btn btn-danger",
                    data: { confirm: "Are you sure you want to delete this show?" } %>
      </div>
    <% end %>

  <% end %>
</div>

<% if current_user&.is_admin %>
  <%= link_to "New show", new_movie_show_path(@movie), class: "btn btn-primary" %>
<% end %>

<%= link_to "Back to Movies", movies_path, class: "btn btn-secondary" %>
