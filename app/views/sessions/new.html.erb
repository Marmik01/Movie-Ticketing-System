<h2>Login</h2>
<%= form_with url: login_path, method: :post do %>
  <div>
    <%= label_tag :username %>
    <%= text_field_tag :username %>
  </div>
  <div>
    <%= label_tag :password %>
    <%= password_field_tag :password %>
  </div>
  <div>
    <%= submit_tag "Login" %>
  </div>
  <%= link_to "Don't have an Account, Sign Up", signup_path %>
<% end %>
