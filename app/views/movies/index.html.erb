<p style="color: green"><%= notice %></p>

<% content_for :title, "Movies" %>

<h1>Movies</h1>

<div id="movies">
  <% @movies.each do |movie| %>
    <%= render movie %>
    <p>
      <%= link_to "Show this movie", movie %>
    </p>
  <% end %>
</div>

<% if current_user&.is_admin %>
  <%= link_to "New Movie", new_movie_path, class: "btn btn-primary" %>
<% end %>
