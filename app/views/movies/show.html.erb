<p class="text-success"><%= notice %></p>

<div class="container mt-4">
  <div class="card shadow-sm">
    <div class="card-body">
      <h2 class="card-title text-center"><%= @movie.title %></h2>

      <div class="row">
        <div class="col-md-6">
          <p><strong>Genre:</strong> <%= @movie.genre %></p>
          <p><strong>Duration:</strong> <%= @movie.duration %> minutes</p>
          <p><strong>Language:</strong> <%= @movie.language %></p>
        </div>
        <div class="col-md-6">
          <p><strong>Rating:</strong> <%= @movie.rating %></p>
          <p><strong>Release Date:</strong> <%= @movie.release_date.strftime('%B %d, %Y') %></p>
        </div>
      </div>

      <div class="text-center mt-3">
        <%= link_to "View Shows", movie_shows_path(@movie), class: "btn btn-info btn-lg" %>
      </div>
    </div>
  </div>

  <div class="mt-4">
    <%= link_to "Back to Movies List", movies_path, class: "btn btn-secondary" %>
  </div>

  <% if current_user&.is_admin %>
    <div class="mt-3">
      <%= link_to "Edit", edit_movie_path(@movie), class: "btn btn-warning" %>
    </div>

    <div class="mt-2">
      <%= link_to "Delete this Movie", delete_movie_path(@movie), class: "btn btn-danger", data: { confirm: "Are you sure you want to delete this movie?" } %>
    </div>
  <% end %>
</div>
